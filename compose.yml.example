# =============================================================================
# TwitterRX 本番環境用 Docker Compose（GHCR イメージベース）
# =============================================================================
#
# VPS 側に以下のファイルを配置してください:
#
#   ~/TwitterRX/
#   ├── compose.yml          ← このファイルをコピー
#   └── .env                 ← Bot 用環境変数（DISCORD_TOKEN 等）
#
# デプロイは GitHub Actions から Webhook 経由で自動実行されます。
# Webhook サーバーのセットアップは scripts/deploy/ を参照してください。
# 必要なポート開放: 9000/tcp (Webhook)
#
# 起動: docker compose up -d
# 更新: docker compose pull && docker compose up -d --force-recreate --remove-orphans
# =============================================================================

services:
  # Discord Bot
  twitter-rx:
    container_name: TwitterRX_Bot
    image: ghcr.io/twitterrx/discord-twitter-embed-rx:${IMAGE_TAG:-latest}
    restart: always
    env_file:
      - .env
    environment:
      - REDIS_URL=redis://redis:6379
    depends_on:
      - redis
    networks:
      - twitterrx_network
    volumes:
      - ./logs:/app/bot/logs
      - ./.config:/app/.config:ro

  # Redis
  redis:
    container_name: TwitterRX_Redis
    image: redis:8.2.2-alpine
    restart: always
    command: redis-server --appendonly yes
    volumes:
      - redis_data:/data
    networks:
      - twitterrx_network
    # 内部通信のみ、ポート公開なし

networks:
  twitterrx_network:
    driver: bridge

volumes:
  redis_data: